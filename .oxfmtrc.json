{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "trailingComma": "all",
  "singleQuote": false,
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "experimentalSortPackageJson": false,
  "sortImports": true,
  "ignorePatterns": [
    "**/routeTree.gen.ts",
    "**/.output/**",
    "**/.vscode/**",
    "**/.cursor/**",
    "**/.agents/**",
    "**/drizzle/meta/**",
    "package-lock.json",
    "pnpm-lock.yaml",
    "yarn.lock",
    "**/src/locales/**/messages.ts"
  ]
}
