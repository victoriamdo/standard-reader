{
  "name": "standard-reader-extension",
  "description": "Save articles and follow publications on the standard.site network.",
  "private": true,
  "version": "0.4.1",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt prepare && wxt build",
    "build:firefox": "wxt prepare && wxt build -b firefox",
    "zip": "wxt prepare && VITE_API_ORIGIN=https://standard-reader.app wxt build && node scripts/zip-chrome.mjs",
    "zip:firefox": "wxt prepare && VITE_API_ORIGIN=https://standard-reader.app wxt build -b firefox && node scripts/zip-firefox.mjs",
    "compile": "wxt prepare && tsc --noEmit"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@lingui/core": "^6.5.0",
    "@lingui/react": "^6.5.0",
    "@stylexjs/stylex": "^0.19.0",
    "kokoro-js": "^1.2.1",
    "lucide-react": "^0.548.0",
    "react": "^19.2.0",
    "react-aria": "^3.49.0",
    "react-aria-components": "^1.18.0",
    "react-dom": "^19.2.0",
    "react-stately": "^3.47.0"
  },
  "devDependencies": {
    "@lingui/babel-plugin-lingui-macro": "^6.5.0",
    "@rolldown/plugin-babel": "0.2.3",
    "@stylexjs/unplugin": "^0.19.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@wxt-dev/module-react": "^1.1.5",
    "browserslist": "^4.28.2",
    "lightningcss": "^1.32.0",
    "typescript": "^6.0.2",
    "wxt": "^0.20.26"
  }
}
