# tap service configuration. Copy to `tap/.env` and fill in. `tap/.env` is
# gitignored. These map to bluesky-social/indigo `cmd/tap` env vars.

# Relay firehose + PLC directory (defaults are fine for the public network).
TAP_RELAY_URL="https://relay1.us-east.bsky.network"
TAP_PLC_URL="https://plc.directory"

# Network boundary + record filtering (defaults set in docker-compose.yml).
# TAP_SIGNAL_COLLECTION="site.standard.publication"
# TAP_COLLECTION_FILTERS="site.standard.publication,site.standard.document,site.standard.graph.subscription,site.standard.graph.recommend,app.bsky.actor.profile"

# Shared secret. tap requires this on its admin API + WebSocket channel, and the
# ingest worker uses the same value as TAP_ADMIN_PASSWORD. Generate:
# openssl rand -hex 32
TAP_ADMIN_PASSWORD=""

TAP_LOG_LEVEL="info"
