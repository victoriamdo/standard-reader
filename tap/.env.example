# tap service configuration. Copy to `tap/.env` and fill in. `tap/.env` is
# gitignored. These map to bluesky-social/indigo `cmd/tap` env vars.

# Relay firehose + PLC directory (defaults are fine for the public network).
TAP_RELAY_URL="https://relay1.us-east.bsky.network"
TAP_PLC_URL="https://plc.directory"

# Network boundary + record filtering (defaults set in docker-compose.yml).
# TAP_SIGNAL_COLLECTION="site.standard.publication"
# TAP_COLLECTION_FILTERS="site.standard.publication,site.standard.document,site.standard.graph.subscription,site.standard.graph.recommend,app.standard-reader.graph.follow,app.bsky.actor.profile,app.standard-reader.read,app.standard-reader.bookmark,app.standard-reader.collection,app.standard-reader.collectionsPublication,app.standard-reader.publicationTheme,app.standard-reader.labelerSubscription,app.standard-reader.labeler.subscription,app.standard-reader.labeler.service"

# Optional second tap instance for labeler discovery (see docker-compose.yml).
# Set to the tap-labeler admin URL (e.g. http://127.0.0.1:2481) on the ingest
# worker so it consumes that channel too.
# TAP_LABELER_API_URL="http://127.0.0.1:2481"

# Optional third tap instance for loose-document discovery. Signals on
# `site.standard.document` so repos with documents but no publication record
# (e.g. Leaflet-hosted) get tracked + backfilled. Set to the tap-docs admin URL
# (e.g. http://127.0.0.1:2482) on the ingest worker so it consumes that channel.
# TAP_DOCS_API_URL="http://127.0.0.1:2482"

# Shared secret. tap requires this on its admin API + WebSocket channel, and the
# ingest worker uses the same value as TAP_ADMIN_PASSWORD. Generate:
# openssl rand -hex 32
TAP_ADMIN_PASSWORD=""

TAP_LOG_LEVEL="info"
