# --- botlabeler config ---

# The DID this labeler publishes under (a did:web serves its own did.json here).
LABELER_DID=did:web:botlabeler.standard-reader.app

# Public origin where this service is reachable. No trailing slash.
PUBLIC_URL=https://botlabeler.standard-reader.app

# secp256k1 private signing key, hex-encoded. Generate one with `pnpm gen-key`.
LABELER_SIGNING_KEY=

# Jetstream firehose endpoint to consume document creates/updates from.
JETSTREAM_URL=wss://jetstream2.us-east.bsky.network/subscribe

# Where to keep the SQLite database (label store + cursors).
SQLITE_PATH=./botlabeler.db

# HTTP/WS port.
PORT=4101

# Bump to re-evaluate every document already seen.
DETECTOR_VERSION=1

# Slingshot is a caching proxy over repo records (profiles, here). Defaults to
# the public instance; set this only if you run your own.
# SLINGSHOT_URL=https://slingshot.microcosm.blue
