{
  "name": "botlabeler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A standalone AT Protocol labeler that labels posts from accounts that have self-declared as bots (a `bot` self-label on their app.bsky.actor.profile).",
  "engines": {
    "node": ">=22.6"
  },
  "scripts": {
    "dev": "node --import tsx --env-file=.env src/index.ts",
    "start": "node --import tsx src/index.ts",
    "gen-key": "node --import tsx scripts/gen-key.ts",
    "backfill": "node --import tsx --env-file=.env scripts/backfill.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@atproto/crypto": "^0.5.0",
    "@ipld/dag-cbor": "^9.2.2",
    "better-sqlite3": "^11.10.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "tsx": "^4.22.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  }
}
