{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "echo 'botlabeler runs TypeScript via tsx; no build step'"
  },
  "deploy": {
    "startCommand": "pnpm --filter botlabeler start",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
