# --- claudeslop labeler config ---

# The DID this labeler publishes under. A did:web is simplest: it resolves to
# https://<host>/.well-known/did.json, which this service serves itself.
LABELER_DID=did:web:claudeslop.standard-reader.app

# Public origin where this service is reachable (used in the DID doc's
# serviceEndpoint). No trailing slash.
PUBLIC_URL=https://claudeslop.standard-reader.app

# secp256k1 private signing key, hex-encoded. Generate one with `pnpm gen-key`.
# The matching public key is published in /.well-known/did.json so anyone can
# verify the labels this service emits. KEEP THIS SECRET.
LABELER_SIGNING_KEY=

# Jetstream firehose endpoint to consume. Any public instance works.
JETSTREAM_URL=wss://jetstream2.us-east.bsky.network/subscribe

# Where to keep the SQLite database (label store + cursors).
SQLITE_PATH=./claudeslop.db

# HTTP/WS port.
PORT=4100

# Detector tuning. Documents scoring at/above AI_THRESHOLD get the `ai-writing`
# label. Bump DETECTOR_VERSION to force a re-scan of everything seen so far.
AI_THRESHOLD=0.62
DETECTOR_VERSION=1

# Slingshot is a caching proxy over repo records (used by the backfill script).
# Defaults to the public instance; set this only if you run your own.
# SLINGSHOT_URL=https://slingshot.microcosm.blue
