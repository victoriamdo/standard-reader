{
  "lexicon": 1,
  "id": "app.standard-reader.getPublicationDocuments",
  "defs": {
    "main": {
      "type": "query",
      "description": "Chronological article feed for a single publication with cursor pagination.",
      "parameters": {
        "type": "params",
        "properties": {
          "publication": {
            "type": "string",
            "format": "at-uri"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 50,
            "default": 20
          },
          "cursor": {
            "type": "string",
            "maxLength": 8192
          }
        },
        "required": ["publication"]
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "app.standard-reader.defs#cursorPageDocuments"
        }
      }
    }
  }
}
