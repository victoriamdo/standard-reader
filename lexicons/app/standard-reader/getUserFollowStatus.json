{
  "lexicon": 1,
  "id": "app.standard-reader.getUserFollowStatus",
  "defs": {
    "main": {
      "type": "query",
      "description": "Whether the subject reader follows a user.",
      "parameters": {
        "type": "params",
        "properties": {
          "did": {
            "type": "string",
            "format": "did",
            "description": "DID of the reader whose follow status is being checked (defaults to the authed reader)."
          },
          "subject": {
            "type": "string",
            "format": "did",
            "description": "DID of the user being followed."
          }
        },
        "required": ["subject"]
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["active"],
          "properties": {
            "active": {
              "type": "boolean"
            }
          }
        }
      }
    }
  }
}
