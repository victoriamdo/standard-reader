{
  "lexicon": 1,
  "id": "app.standard-reader.getUserSubscriptions",
  "defs": {
    "main": {
      "type": "query",
      "description": "Publications a DID subscribes to, most recently subscribed first, with cursor pagination.",
      "parameters": {
        "type": "params",
        "properties": {
          "did": {
            "type": "string",
            "format": "did"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 50,
            "default": 20
          },
          "cursor": {
            "type": "string",
            "maxLength": 8192
          }
        },
        "required": ["did"]
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "app.standard-reader.defs#cursorPagePublications"
        }
      }
    }
  }
}
