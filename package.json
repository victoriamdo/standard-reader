{
  "name": "my-tanstack-app",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=22.6"
  },
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "start": "node --require @opentelemetry/auto-instrumentations-node/register .output/server/index.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "perf:discover-fixtures": "pnpm exec tsx --env-file=.env scripts/perf-discover-fixtures.ts",
    "api-docs:examples": "pnpm exec tsx --env-file=.env scripts/run-api-docs-examples.ts",
    "perf:test": "playwright test",
    "perf:test:guest": "playwright test --grep \"load regression — guest\"",
    "perf:test:signed-in": "playwright test --grep \"load regression — signed in\"",
    "perf:view": "node scripts/perf-view.mjs",
    "perf:explain": "FEED_PERF_TEST=1 vitest run src/server/reader/queries.explain.test.ts",
    "ingest:dev": "tsx --env-file=.env --require @opentelemetry/auto-instrumentations-node/register src/server/ingest/service.ts",
    "ingest:start": "tsx --require @opentelemetry/auto-instrumentations-node/register src/server/ingest/service.ts",
    "digest:send": "tsx scripts/send-weekly-digest.ts",
    "digest:send:dev": "tsx --env-file=.env scripts/send-weekly-digest.ts",
    "thread:post": "tsx scripts/post-weekly-thread.ts",
    "thread:post:dev": "tsx --env-file=.env scripts/post-weekly-thread.ts",
    "backfill:actor-handles": "pnpm exec tsx --env-file=.env scripts/backfill-actor-handles.ts",
    "backfill:search-text": "pnpm exec tsx --env-file=.env scripts/backfill-search-text.ts",
    "backfill:renderable": "pnpm exec tsx --env-file=.env scripts/backfill-renderable-body.ts",
    "backfill:content-formats": "pnpm exec tsx --env-file=.env scripts/backfill-content-formats.ts",
    "backfill:repo-documents": "pnpm exec tsx --env-file=.env scripts/backfill-repo-documents.ts",
    "backfill:lists": "pnpm exec tsx --env-file=.env scripts/backfill-lists.ts",
    "scan:unsupported-blocks": "pnpm exec tsx --env-file=.env scripts/scan-unsupported-blocks.ts",
    "scan:discussion-sources": "pnpm exec tsx --env-file=.env scripts/scan-discussion-sources.ts",
    "icons:generate": "node scripts/generate-social-icon.mjs",
    "honeycomb:seed": "node --env-file=.env scripts/honeycomb-seed.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm exec oxlint .",
    "lint:react-compiler": "eslint -c eslint.react-compiler.mjs --quiet src",
    "format": "pnpm exec oxfmt",
    "format:check": "pnpm exec oxfmt --check",
    "check": "pnpm exec oxfmt && pnpm exec oxlint . --fix",
    "fix-stylex-keys": "eslint -c eslint.stylex-autofix.mjs --fix --no-inline-config src",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile --typescript",
    "i18n:check": "lingui extract --strict",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "lex:lint": "node scripts/goat-lex.mjs lex lint lexicons/app/standard-reader",
    "lex:status": "node scripts/goat-lex.mjs lex status",
    "atproto:publish-lexicons": "node scripts/goat-lex.mjs lex publish --update",
    "lexicons:generate": "pnpm --filter @standard-reader/lexicons generate",
    "lexicons:build": "pnpm --filter @standard-reader/lexicons build",
    "packages:build": "pnpm -r --filter \"./packages/**\" run build",
    "packages:publish": "node scripts/publish-packages.mjs",
    "packages:publish:dry": "node scripts/publish-packages.mjs --dry-run",
    "extension:dev": "pnpm --filter standard-reader-extension dev",
    "extension:build": "pnpm --filter standard-reader-extension build",
    "extension:zip": "pnpm --filter standard-reader-extension zip",
    "extension:build:firefox": "pnpm --filter standard-reader-extension build:firefox",
    "extension:zip:firefox": "pnpm --filter standard-reader-extension zip:firefox",
    "register-labelers": "pnpm exec tsx --env-file=.env scripts/register-labelers.ts",
    "sync-labels": "pnpm exec tsx --env-file=.env scripts/sync-labels.ts",
    "feedback:poll": "pnpm exec tsx scripts/feedback-agent-poll.ts",
    "feedback:poll:dev": "DRY_RUN=1 pnpm exec tsx --env-file=.env scripts/feedback-agent-poll.ts",
    "feedback:status": "pnpm exec tsx scripts/feedback-agent-status.ts",
    "feedback:status:dev": "pnpm exec tsx --env-file=.env scripts/feedback-agent-status.ts",
    "fonts:generate": "node scripts/generate-font-fallbacks.mjs"
  },
  "dependencies": {
    "@atcute/atproto": "^4.0.3",
    "@atcute/client": "^5.1.1",
    "@atcute/identity-resolver": "^2.0.1",
    "@atcute/identity-resolver-node": "^2.0.1",
    "@atcute/lexicons": "^2.0.2",
    "@atcute/oauth-node-client": "^2.0.1",
    "@atcute/password-session": "^1.0.1",
    "@atcute/tid": "^1.1.3",
    "@atproto/tap": "^0.3.0",
    "@atproto/xrpc-server": "^0.11.1",
    "@fontsource-variable/atkinson-hyperlegible-next": "^5.2.6",
    "@fontsource/atkinson-hyperlegible-next": "^5.2.7",
    "@fontsource/newsreader": "^5.2.10",
    "@huggingface/transformers": "^4.2.0",
    "@lingui/core": "^6.5.0",
    "@lingui/react": "^6.5.0",
    "@neondatabase/serverless": "^1.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.57.1",
    "@origin-space/image-cropper": "^0.1.9",
    "@plausible-analytics/tracker": "^0.4.5",
    "@radix-ui/colors": "^3.0.0",
    "@react-aria/overlays": "^3.32.1",
    "@react-aria/utils": "^3.34.1",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.1.0",
    "@react-stately/utils": "^3.12.1",
    "@react-types/overlays": "^3.10.0",
    "@resvg/resvg-js": "^2.6.2",
    "@standard-reader/renderer-core": "workspace:*",
    "@standard-reader/renderer-react": "workspace:*",
    "@stylexjs/stylex": "^0.19.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "@window-splitter/react": "^1.1.3",
    "bezier-easing": "^3.0.0",
    "bsky-react-post": "^0.1.7",
    "colorjs.io": "^0.6.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "katex": "^0.17.0",
    "kokoro-js": "^1.2.1",
    "lucide-react": "^0.548.0",
    "marked": "^18.0.5",
    "media-chrome": "^4.19.1",
    "nitro": "3.0.260603-beta",
    "pg": "^8.21.0",
    "react": "19.3.0-canary-ad78e251-20260616",
    "react-aria": "^3.49.0",
    "react-aria-components": "^1.18.0",
    "react-dom": "19.3.0-canary-ad78e251-20260616",
    "react-markdown": "^10.1.0",
    "react-stately": "^3.47.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "satori": "^0.26.0",
    "shiki": "^4.2.0",
    "swr": "^2.4.1",
    "tsx": "^4.22.4",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "universal-cookie": "^8.1.2",
    "web-haptics": "^0.0.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capsizecss/core": "^4.1.3",
    "@capsizecss/metrics": "^4.1.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.5.0",
    "@lingui/babel-plugin-lingui-macro": "^6.5.0",
    "@lingui/cli": "^6.5.0",
    "@lingui/format-po": "^6.5.0",
    "@lingui/vite-plugin": "^6.5.0",
    "@playwright/test": "^1.60.0",
    "@rolldown/plugin-babel": "0.2.3",
    "@stylexjs/eslint-plugin": "^0.19.0",
    "@stylexjs/unplugin": "^0.19.0",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@tanstack/intent": "^0.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/fontkit": "^2.0.9",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-react": "^6.0.1",
    "browserslist": "^4.28.2",
    "eslint": "^9.39.4",
    "eslint-plugin-perfectionist": "^4.15.1",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "fontkit": "^2.0.4",
    "hip-ui": "^0.3.0",
    "jsdom": "^28.1.0",
    "lightningcss": "^1.32.0",
    "oxfmt": "latest",
    "oxlint": "1.48.0",
    "typescript": "^6.0.2",
    "vite": "8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5",
    "workbox-window": "^7.4.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "lightningcss"
    ],
    "overrides": {
      "@huggingface/transformers": "^4.2.0",
      "react": "19.3.0-canary-ad78e251-20260616",
      "react-dom": "19.3.0-canary-ad78e251-20260616",
      "unplugin": "^3.0.0",
      "@tanstack/router-core": "1.171.15"
    }
  }
