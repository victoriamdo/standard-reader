{
  "name": "@standard-reader/renderer-angular",
  "version": "0.2.0",
  "description": "Headless, unstyled Angular renderer for Standard Site documents.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "clean": "rm -rf dist",
    "typecheck": "ngc -p tsconfig.json",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "keywords": [
    "standard-reader",
    "atproto",
    "leaflet",
    "renderer",
    "headless",
    "angular"
  ],
  "dependencies": {
    "@standard-reader/renderer-core": "workspace:*",
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "@angular/common": "^18.0.0 || ^19.0.0",
    "@angular/core": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/compiler-cli": "^19.2.0",
    "@angular/core": "^19.2.0",
    "ng-packagr": "^19.2.0",
    "rxjs": "^7.8.1",
    "typescript": "5.6.3",
    "zone.js": "^0.15.0"
  }
}
