{
  "name": "@standard-reader/renderer-svelte",
  "version": "0.2.0",
  "description": "Headless, unstyled Svelte 5 renderer for Standard Site documents.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "svelte-package -i src -o dist",
    "prepare": "svelte-package -i src -o dist",
    "clean": "rm -rf dist",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "standard-reader",
    "atproto",
    "leaflet",
    "renderer",
    "headless",
    "svelte"
  ],
  "dependencies": {
    "@standard-reader/renderer-core": "workspace:*"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.3.7",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "jsdom": "^28.1.0",
    "svelte": "^5.19.0",
    "svelte-check": "^4.1.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  }
}
