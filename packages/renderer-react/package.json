{
  "name": "@standard-reader/renderer-react",
  "version": "0.2.0",
  "description": "Headless, unstyled React renderer for Standard Site documents. Bring your own components.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "keywords": [
    "standard-reader",
    "atproto",
    "leaflet",
    "renderer",
    "headless",
    "react"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@standard-reader/renderer-core": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "jsdom": "^28.1.0",
    "react": "19.3.0-canary-ad78e251-20260616",
    "react-dom": "19.3.0-canary-ad78e251-20260616",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  }
}
