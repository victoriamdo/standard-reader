# Standard Reader — environment variables
#
# Copy this file to `.env` and fill in real values. `.env` / `.env.*` are gitignored
# (only `.env.example` is committed).
#
# TanStack Start env model: ONLY variables prefixed with `VITE_` are exposed to the
# browser. Everything else is server-only — keep all secrets unprefixed.

# ──────────────────────────────────────────────────────────────────────────────
# Database — Neon Postgres (read-model / cache)
# ──────────────────────────────────────────────────────────────────────────────
# Pooled connection string from the Neon dashboard (used by the app + drizzle-kit).
DATABASE_URL="postgresql://[user]:[password]@[neon_hostname]/[dbname]?sslmode=require&channel_binding=require"

# ──────────────────────────────────────────────────────────────────────────────
# Analytics — Plausible (client-side, `@plausible-analytics/tracker`)
# ──────────────────────────────────────────────────────────────────────────────
# Site domain as registered in Plausible. Leave blank to disable tracking.
VITE_PLAUSIBLE_DOMAIN="standard-reader.app"
# Optional: proxy endpoint (see https://plausible.io/docs/proxy/introduction).
# VITE_PLAUSIBLE_ENDPOINT="https://standard-reader.app/api/plausible/event"
# Set to "true" to send events from localhost during dev (default: off).
# VITE_PLAUSIBLE_CAPTURE_ON_LOCALHOST="true"

# ──────────────────────────────────────────────────────────────────────────────
# Observability — Honeycomb (server-side structured events)
# ──────────────────────────────────────────────────────────────────────────────
# The app emits structured JSON via `src/server/observability/log.ts` (`observe`,
# `logEvent`). When HONEYCOMB_API_KEY is set, the same events are batched to
# Honeycomb's Events API (Railway has no log drain, so stdout alone is not enough).
# Leave blank for local dev (stdout-only).
HONEYCOMB_API_KEY=""
# Dataset name (created on first event). Use one dataset per app/environment.
HONEYCOMB_DATASET="standard-reader"
# Optional service label on every event. Defaults to Railway's RAILWAY_SERVICE_NAME
# (set explicitly on each Railway service if you want "web" / "ingest" labels).
# HONEYCOMB_SERVICE="web"
# Optional: EU Honeycomb instance — https://api.eu1.honeycomb.io
# HONEYCOMB_API_HOST="https://api.honeycomb.io"

# ──────────────────────────────────────────────────────────────────────────────
# App / server
# ──────────────────────────────────────────────────────────────────────────────
# Public base URL of the deployed app (no trailing slash). The AT Proto OAuth
# client derives its client_id (`${PUBLIC_URL}/api/auth/atproto/metadata.json`),
# jwks_uri, and redirect URI (`${PUBLIC_URL}/api/auth/atproto/callback`) from it.
#
# Local dev: use http://127.0.0.1:3000 — AT Proto treats `localhost`/`127.0.0.1`
# base URLs as a public (loopback) client, so no signing key is needed locally.
PUBLIC_URL="http://127.0.0.1:3000"

# Constellation backlink index — discovers Bluesky posts and margin.at notes linking article URLs.
# Default public instance; override to point at a self-hosted Constellation.
CONSTELLATION_URL="https://constellation.microcosm.blue"

# Slingshot (microcosm) — optional fallback for repo reads (e.g. Sifa `id.sifa.profile.self`).
# SLINGSHOT_URL="https://slingshot.microcosm.blue"

# ──────────────────────────────────────────────────────────────────────────────
# Auth — AT Proto / Bluesky OAuth (@atcute/oauth-node-client)
# ──────────────────────────────────────────────────────────────────────────────
# In production (non-loopback PUBLIC_URL) the app runs as a *confidential* OAuth
# client and must authenticate with a private signing key. Set this to an ES256
# private key as a JWK JSON string (one line). It is served (public half only)
# at `${PUBLIC_URL}/api/auth/atproto/jwks.json`.
#
# Generate one with @atcute/oauth-node-client, e.g.:
#   node -e "import('@atcute/oauth-node-client').then(async m => console.log(JSON.stringify(await m.generateClientAssertionKey('standard-reader-oauth'))))"
# The `kid` argument is REQUIRED: the signed client_assertion advertises it and
# the auth server uses it to find the matching key in the published JWKS. A key
# without a `kid` fails login with "no applicable key found in the JSON Web Key
# Set". (Any ES256 JWK works as long as it has a `kid`.) Leave blank for local
# loopback dev.
ATPROTO_PRIVATE_KEY_JWK=""

# ──────────────────────────────────────────────────────────────────────────────
# Ingestion — standalone tap consumer service
# ──────────────────────────────────────────────────────────────────────────────
# The `tap` service (bluesky-social/indigo cmd/tap) runs separately and POSTs
# verified firehose/backfill events to the standalone Node consumer started with
# `pnpm ingest:dev`. The tap service itself is configured in `tap/.env` (see
# `tap/README.md`). The vars below are the consumer-service knobs.
#
# Port for the standalone consumer (`/api/ingest/status`,
# `/api/ingest/recompute`, `/health`). tap events are pulled over the tap
# WebSocket channel and acked after DB commit.
INGEST_PORT="3099"
# Shared secret the ingestion admin routes require.
# Must equal the tap service's TAP_ADMIN_PASSWORD. Generate with:
# openssl rand -hex 32
INGEST_WEBHOOK_SECRET=""
# Optional: tap's admin API base URL. When set, the app and ingest worker dynamically
# track newly-discovered repos via `/repos/add` (expands the index along the graph).
# On Railway, set this on **both** the `web` and `ingest` services (e.g.
# `http://tap.railway.internal:2480`). Without it on `web`, follows still land in
# `tracked_repos` but tap registration waits for the ingest worker's reconcile loop.
# Leave blank locally to seed tap statically instead (`tap/seed-repos.sh`).
TAP_API_URL="http://127.0.0.1:2480"
# Must match TAP_API_URL's admin password (alias for INGEST_WEBHOOK_SECRET if unset).
TAP_ADMIN_PASSWORD=""
# PLC directory used for DID → PDS/handle resolution (blob URLs, profile enrich).
TAP_PLC_URL="https://plc.directory"

# ──────────────────────────────────────────────────────────────────────────────
# Lexicon publishing — app-owned `app.standard-reader.*` schemas
# ──────────────────────────────────────────────────────────────────────────────
# The lexicons live in `./lexicons/` and are published as `com.atproto.lexicon.schema`
# records via the `goat` CLI (install: https://github.com/bluesky-social/goat):
#   pnpm lex:lint                  # validate schemas
#   pnpm atproto:publish-lexicons  # upload new/updated schemas to the account below
#
# Credentials for the account that controls the `standard-reader.app` NSID
# authority. Use an app password (Bluesky settings → App Passwords), NOT the main
# password. Publishing also requires `_lexicon.standard-reader.app` DNS TXT
# records resolving to this account's DID — see `goat lex check-dns`.
LEXICON_PUBLISH_IDENTIFIER=""
LEXICON_PUBLISH_APP_PASSWORD=""

# ──────────────────────────────────────────────────────────────────────────────
# Perf regression — Playwright load budgets (local / CI optional)
# ──────────────────────────────────────────────────────────────────────────────
# Base URL for perf tests (defaults to http://127.0.0.1:3000). Reuses a running
# `pnpm dev` when available (see playwright.config.ts).
# PERF_TEST_BASE_URL="http://127.0.0.1:3000"
#
# Signed-in suite (preferred): Bluesky handle + app password (Settings → App
# Passwords). The perf runner logs in once per run and seeds a dev session.
# Also set PERF_TEST_APP_PASSWORD on the dev server (.env) so it can restore
# the app-password AT Proto client alongside the session cookie.
# PERF_TEST_IDENTIFIER="your.handle.bsky.social"
# PERF_TEST_APP_PASSWORD="xxxx-xxxx-xxxx-xxxx"
#
# Optional: override PDS for login (defaults to https://bsky.social).
# PERF_TEST_PDS_URL="https://bsky.social"
#
# Legacy fallback: paste the HttpOnly `standard-reader-auth.session_token` cookie
# after OAuth login (requires a matching OAuth session in the DB).
# PERF_TEST_SESSION_TOKEN=""
#
# Discover stable article/publication/tag fixtures from your DB:
#   pnpm perf:discover-fixtures
# PERF_TEST_ARTICLE_PATH="/a/did:plc:…/rkey"
# PERF_TEST_PUBLICATION_PATH="/p/did:plc:…/rkey"
# PERF_TEST_TAG="observability"
# PERF_TEST_SEARCH_QUERY="reader"
# Collection editor target (signed-in). rkey of a readerCollection doc in the
# signed-in user's repo — pick one with many items. Skipped when unset.
# PERF_TEST_COLLECTION_RKEY="rkey"            # or PERF_TEST_COLLECTION_EDIT_PATH="/collections/edit/rkey"
#
# Scale all time budgets on slow runners (default 1).
# PERF_BUDGET_MULTIPLIER="1.5"
# PERF_TEST_TIMEOUT_MS="60000"
# PERF_TEST_WARMUP_PASSES="1"
#
# View the latest JSON report in a browser:
#   pnpm perf:view   # http://127.0.0.1:3098

# ──────────────────────────────────────────────────────────────────────────────
# API docs — live curl examples (/docs/api)
# ──────────────────────────────────────────────────────────────────────────────
# Examples auto-discover publication/article/tag fixtures from the DB when unset.
# Override any field explicitly, or reuse PERF_TEST_* vars (see above).
# List endpoints need a real public list on a PDS:
# API_DOCS_FIXTURE_LIST_URI="at://did:plc:…/app.standard-reader.list/…"
# Smoke-test all auto-runnable examples:
#   pnpm api-docs:examples
